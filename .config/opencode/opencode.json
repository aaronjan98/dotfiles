{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 15000,
      "type": "local"
    }
  },
  "model": "ollama/glm-4.7-flash",
  "provider": {
    "ollama": {
      "models": {
        "glm-4.7-flash": {
          "_launch": true,
          "name": "glm-4.7-flash"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "tui": {
    "cursor_blink": false,
    "cursor_color": "#FF2800",
    "cursor_style": "line"
  }
}
