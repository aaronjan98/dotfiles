{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "cursor_color": "#FF2800",
    "cursor_style": "line",
    "cursor_blink": false
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--headless"],
      "enabled": true,
      "timeout": 15000
    }
  }
}
