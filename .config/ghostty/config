background = 1a0810
background-opacity = 0.75

cursor-style = block
cursor-style-blink = true
cursor-color = #FF2800
cursor-text = #000000
custom-shader = /home/aj/.config/ghostty/shaders/cursor_smear.glsl

# Notify when a command finishes while the window is unfocused (1.3.0+)
# Works natively via shell integration (OSC 133). For tmux panes, see ~/.bashrc.
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 10s
